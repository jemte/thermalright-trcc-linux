#!/bin/sh
set -e

case "$1" in
    configure)
        # Reload udev rules
        if command -v udevadm >/dev/null 2>&1; then
            udevadm control --reload-rules 2>/dev/null || true
            udevadm trigger 2>/dev/null || true
        fi

        # Load sg module immediately
        modprobe sg 2>/dev/null || true
        ;;
esac

#DEBHELPER#

exit 0
